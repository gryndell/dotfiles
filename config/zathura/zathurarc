# set index-active-fg             "#eee8d5"

set statusbar-v-padding  15
set statusbar-h-padding  15
set font "Cozette 11"
set pages-per-row 1
set statusbar-basename          true
set page-padding 1
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out

